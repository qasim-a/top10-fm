# Last.fm API credentials
# Get yours at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# AWS configuration
AWS_REGION=us-east-1

# DynamoDB table names
# These match the defaults in db.py — only change if you rename your tables
USERS_TABLE=top10fm-users
CHARTS_TABLE=top10fm-charts
RECORDS_TABLE=top10fm-records

# SAM local development only
# These are set automatically when deployed to AWS
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here